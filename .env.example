# Google Cloud Platform — required for baseline measurement (Phase 1d)
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then load with:
#   export $(cat .env | xargs)

# GCP Project ID (not project number)
GCP_PROJECT=your-gcp-project-id

# Document AI location (e.g., "us", "eu")
GCP_LOCATION=us

# Document AI Processor ID (create at https://console.cloud.google.com/ai/document-ai/processors)
DOCAI_PROCESSOR_ID=your-processor-id

# Gemini model for error detection (gemini-2.5-flash, gemini-2.5-pro, etc.)
GEMINI_MODEL=gemini-2.5-flash

# Alternative: if using API key instead of ADC
# GOOGLE_API_KEY=your-api-key
